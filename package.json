{
  "name": "deploy-shield",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.base.json",
    "lint": "eslint . --max-warnings 0 && prettier --check .",
    "check": "pnpm run test && pnpm run typecheck && pnpm exec jscpd . && pnpm exec vitest run --coverage && node scripts/changed-coverage.mjs && pnpm audit --audit-level high && (command -v osv-scanner >/dev/null 2>&1 || { echo \"osv-scanner missing — run 'mise install'\"; exit 1; }) && osv-scanner scan --lockfile=pnpm-lock.yaml"
  },
  "devDependencies": {
    "@stryker-mutator/core": "9.6.1",
    "@stryker-mutator/vitest-runner": "9.6.1",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "dependency-cruiser": "18.1.0",
    "eslint": "10.7.0",
    "jscpd": "5.0.12",
    "lefthook": "2.1.10",
    "license-checker-rseidelsohn": "5.0.1",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "lefthook"
    ],
    "overrides": {
      "qs": ">=6.15.2"
    }
  },
  "deployShield": {
    "changedFileCoverage": 85,
    "templateVersion": "1.0.0"
  }
}
